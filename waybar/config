{
    "layer": "top",
    "position": "top",
    "spacing": 0,
    "height": 38,
    "modules-left": [
        "custom/logo",
        "hyprland/workspaces"
    ],
    "modules-center": [
        "custom/player"
    ],
    "custom/player": {
        "exec": "~/.config/waybar/scripts/player",
        "format": "{}",
        "interval": 2,
        "return-type": "json",
        "on-click": "playerctl play-pause"
    },
    "modules-right": [
        "tray",
        "network",
        "custom/kernel",
        "cpu",
        "memory",
        "custom/diskfree",
        "clock",
        "wireplumber",
        "custom/exit"
    ],
    "hyprland/workspaces": {
        "on-click": "activate",
        "disable-scroll": true,
        "all-outputs": true,
        "warp-on-scroll": false,
        "format": "{name}: {icon}",
        "format-icons": {
            "1": "",
            "2": "",
            "3": "",
            "4": "󰴒",
            "5": "",
            "6": "󰙯",
            "7": "󰎈",
            "urgent": "",
            "default": ""
        },
        "persistent-workspaces": { }
    },
    "cpu": {
        "format": "  {usage}%" 
    },
    "memory": {
        "interval": 5,
        "format": " {}%",
        "max-length": 15
    },
    "tray": {
        "spacing": 10
    },
    "clock": {
        "tooltip-format": "{calendar}",
        "format-alt": "  {:%a, %b %d %Y}",
        "format": "  {:%Y/%m/%d | %H:%M}"
    },
    "network": {
        "format-wifi" : "{icon} {ipaddr}/{cidr}",
        "format-icons": ["󰤯","󰤟","󰤢","󰤥","󰤨"],
        "format-ethernet": "󰀂  {ipaddr}/{cidr}",
        "format-alt" : "󱛇",
        "format-disconnected" : "󰖪",
        "tooltip-format-wifi": "{icon} {essid}\n⇣{bandwidthDownBytes}  ⇡{bandwidthUpBytes}",
        "tooltip-format-ethernet": "󰀂  {ifname}\n⇣{bandwidthDownBytes}  ⇡{bandwidthUpBytes}",
        "tooltip-format-disconnected": "Disconnected",
        "on-click": "~/.config/rofi/wifi/wifi.sh &",
        "on-click-right": "~/.config/rofi/wifi/wifinew.sh &",
        "interval": 5,
        "nospacing": 1,
    },
    "wireplumber": {
        "format": "{icon} {volume}%",
        "format-bluetooth": "󰂰",
        "nospacing": 1,
        "tooltip-format": "Volume : {volume}%",
        "format-muted": "󰝟",
        "format-icons": {
            "headphone": "",
            "default": ["󰖀","󰕾",""]
        },
        "on-click": "pamixer -t",
        "scroll-step": 1
    },
    "custom/logo": {
        "format": " ",
        "tooltip": false,
        "on-click": "rofi -show drun &"
    },
    "custom/kernel": {
        "format": " {}",
        "interval": 3600,
        "tooltip-format": "Linux Kernel Version: {}",
        "max-length": 20,
        "exec": "uname -r"
    },
    "custom/diskfree": {
        "format": "🖴 {}",
        "interval": 300,
        "max-length": 20,
        "exec": "df --total -hl | grep 'nvme1n1p2' | awk '{print $5}'"
    },
    "custom/exit": {
        "format": "",
        "on-click": "wlogout -b 5",
        "on-click-right": "hyprlock",
        "tooltip-format": "Left: Power menu\nRight: Lock screen"
     },
}
